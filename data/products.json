const SALAI_COLORS = ["#FF3B30", "#FFFFFF", "#444444", "#FFD600", "#FF47B6", "#A100FF", "#00D1FF"];

let PRODUCT_DATA = []; // Will be populated from JSON
let cart = JSON.parse(localStorage.getItem('pe_cart')) || [];
