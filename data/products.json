let audioCtx, hardwareReady = false;

// 2. Fetch Data from JSON
async function loadRegistry() {
    try {
        const response = await fetch('data/products.json');
        PRODUCT_DATA = await response.json();
        renderGrid();
        updateCartUI();
    } catch (e) {
        console.error("Registry Load Failure", e);
    }
}

// 3. MEETE MAYEK SPLASH EFFECT (FIXED)
const handleInteraction = (e) => {
    if(document.getElementById('loader').style.display !== 'none') return;
    primeHardware();
    playTock();
    
    const x = e.clientX || (e.touches && e.touches[0].clientX);
    const y = e.clientY || (e.touches && e.touches[0].clientY);
    if(!x || !y) return;

    const mayekChars = "ꯀꯁꯂꯃꯄꯅꯆꯇꯈꯉꯊꯋꯌꯍꯎꯏꯐꯑꯒꯓꯔꯕꯖꯗꯘꯙꯚ";
    for(let i=0; i<6; i++) { // Increased count for better feel
        const p = document.createElement('div');
        p.className = 'particle';
        p.innerText = mayekChars[Math.floor(Math.random()*mayekChars.length)];
        p.style.left = `${x}px`;
        p.style.top = `${y}px`;
        p.style.color = SALAI_COLORS[Math.floor(Math.random()*SALAI_COLORS.length)];
        p.style.setProperty('--tx', `${(Math.random()-0.5)*200}px`);
        p.style.setProperty('--ty', `${-150-Math.random()*200}px`);
        p.style.setProperty('--tr', `${(Math.random()-0.5)*360}deg`);
        document.body.appendChild(p);
        setTimeout(() => p.remove(), 1200);
    }
};

window.addEventListener('mousedown', handleInteraction);
window.addEventListener('touchstart', handleInteraction, {passive:true});

// [Rest of your rendering and checkout logic remains the same, 
// just ensure window.onload calls loadRegistry()]

window.onload = () => {
    loadRegistry(); // Initial load
    setTimeout(() => {
        // Matrix & Typewriter logic...
        document.getElementById('loader').style.display = 'none';
    }, 2500);
};
